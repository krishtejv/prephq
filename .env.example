# PrepHQ Homelab Production Environment Variables
# Copy this file to '.env' on your homelab host and update the values.
# DO NOT commit the '.env' file containing real secrets to GitHub!

# ── JWT AUTHENTICATION ────────────────────────────────────────────────────────
# A long, random secure string to sign authentication tokens.
# Example: openssl rand -hex 32
JWT_SECRET=replace_this_with_a_secure_random_string_32_chars_or_more

# ── PORT CONFIGURATION ────────────────────────────────────────────────────────
# Ports exposed on your homelab host.
# Since your host Nginx is on port 81 and 443, serve the frontend container
# on port 8080 (or any free port) and reverse-proxy to it from your host Nginx.
FRONTEND_PORT=8080
BACKEND_PORT=5001

# ── CORS ALLOWED ORIGIN ───────────────────────────────────────────────────────
# The domain or IP/port you use to access the dashboard in the browser.
# If you reverse-proxy through host Nginx (e.g. http://your-homelab-ip:81),
# set this to that exact origin.
ALLOWED_ORIGIN=http://localhost:8080
