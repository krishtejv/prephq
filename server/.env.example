# PrepHQ Backend — Environment Variable Template
# Copy this file to .env and fill in real values before running the server.
# ⚠️  The actual .env file is gitignored — never commit real secrets.

# JWT signing secret — generate with:
#   node -e "const crypto = require('crypto'); console.log(crypto.randomBytes(64).toString('hex'));"
JWT_SECRET=your-cryptographically-random-secret-here

# Allowed frontend origin for CORS (no trailing slash)
ALLOWED_ORIGIN=http://localhost:5173

# Server port
PORT=5001
